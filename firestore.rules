rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return isSignedIn() ? myProfile().role : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && myRole() == 'super-admin';
    }

    function isAdminLevel() {
      return isSignedIn() && myRole() in ['super-admin', 'administrator'];
    }

    function isStaff() {
      return isSignedIn() &&
        myRole() in ['super-admin', 'administrator', 'administrative-staff', 'teacher'];
    }

    function isAdminLevelRole(role) {
      return role in ['super-admin', 'administrator'];
    }

    // An Administrator (not Super Admin) may only touch accounts whose
    // role — before and after the write — is NOT admin-level. Super Admin
    // is unrestricted. This mirrors the Cloud Functions callables, which
    // are the primary write path; these rules are the defense-in-depth
    // backstop for any direct Firestore access.
    function canManageTargetRole(role) {
      return isSuperAdmin() || (isAdminLevel() && !isAdminLevelRole(role));
    }

    // ── users/{uid} ────────────────────────────────────────────────────
    // Everyone can read their own profile. Staff can read any profile
    // (needed for rosters, staff directories, the user management list,
    // search, and filters). Only Super Admin / Administrator can create
    // or edit accounts, and never accounts more privileged than what an
    // Administrator is allowed to touch. A user may update a narrow set
    // of their own fields (e.g. displayName) but never their own role or
    // status.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaff());

      allow create: if isAdminLevel() && canManageTargetRole(request.resource.data.role);

      allow update: if
        (isAdminLevel() &&
          canManageTargetRole(resource.data.role) &&
          canManageTargetRole(request.resource.data.role)) ||
        (isSignedIn() && request.auth.uid == uid &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status);

      allow delete: if isAdminLevel() && canManageTargetRole(resource.data.role);
    }

    // Everything else defaults closed until later phases define the
    // students / classes / grades / fees collections explicitly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
